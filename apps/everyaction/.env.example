# EveryAction API credentials (from EA > API Integrations)
EVERYACTION_API_KEY=your_generated_api_key_here
EVERYACTION_APP_NAME=TSM01.000001.698
EVERYACTION_MODE=1

# MCP OAuth shared secret
# Staff enter this as the OAuth Client Secret when adding the connector in Claude.ai
# Use any strong random string: openssl rand -hex 32
MCP_CLIENT_SECRET=generate_a_random_secret_here

# Public URL of this deployment (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
